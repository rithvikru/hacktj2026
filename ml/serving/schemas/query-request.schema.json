{
  "$defs": {
    "LocalCapabilities": {
      "additionalProperties": false,
      "properties": {
        "localAcceleratorAvailable": {
          "default": false,
          "title": "Localacceleratoravailable",
          "type": "boolean"
        },
        "supportedLabels": {
          "items": {
            "type": "string"
          },
          "title": "Supportedlabels",
          "type": "array"
        }
      },
      "title": "LocalCapabilities",
      "type": "object"
    },
    "ObservationSummary": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "evidenceClass": {
          "anyOf": [
            {
              "enum": [
                "detected",
                "last_seen",
                "signal_estimated",
                "likely_hidden",
                "not_found"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Evidenceclass"
        },
        "label": {
          "title": "Label",
          "type": "string"
        },
        "observedAt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Observedat"
        },
        "source": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source"
        },
        "worldTransform16": {
          "anyOf": [
            {
              "items": {
                "type": "number"
              },
              "maxItems": 16,
              "minItems": 16,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Worldtransform16"
        }
      },
      "required": [
        "label",
        "confidence"
      ],
      "title": "ObservationSummary",
      "type": "object"
    },
    "RoomMetadataSummary": {
      "additionalProperties": false,
      "properties": {
        "prominentFurniture": {
          "items": {
            "type": "string"
          },
          "title": "Prominentfurniture",
          "type": "array"
        },
        "prominentSurfaces": {
          "items": {
            "type": "string"
          },
          "title": "Prominentsurfaces",
          "type": "array"
        },
        "roomName": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Roomname"
        },
        "sections": {
          "items": {
            "type": "string"
          },
          "title": "Sections",
          "type": "array"
        }
      },
      "title": "RoomMetadataSummary",
      "type": "object"
    },
    "SceneGraphSummary": {
      "additionalProperties": false,
      "properties": {
        "relationFacts": {
          "items": {
            "type": "string"
          },
          "title": "Relationfacts",
          "type": "array"
        },
        "salientNodes": {
          "items": {
            "type": "string"
          },
          "title": "Salientnodes",
          "type": "array"
        }
      },
      "title": "SceneGraphSummary",
      "type": "object"
    },
    "SignalCapabilities": {
      "additionalProperties": false,
      "properties": {
        "cooperativeAvailable": {
          "default": false,
          "title": "Cooperativeavailable",
          "type": "boolean"
        },
        "tagSupportAvailable": {
          "default": false,
          "title": "Tagsupportavailable",
          "type": "boolean"
        }
      },
      "title": "SignalCapabilities",
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "frameRefs": {
      "items": {
        "type": "string"
      },
      "title": "Framerefs",
      "type": "array"
    },
    "frameSelectionMode": {
      "default": "live_priority",
      "enum": [
        "live_priority",
        "saved_priority",
        "hybrid",
        "explicit_frame_refs"
      ],
      "title": "Frameselectionmode",
      "type": "string"
    },
    "localCapabilities": {
      "$ref": "#/$defs/LocalCapabilities"
    },
    "objectPrototypeCatalog": {
      "items": {
        "type": "string"
      },
      "title": "Objectprototypecatalog",
      "type": "array"
    },
    "priorQueryHistory": {
      "items": {
        "type": "string"
      },
      "title": "Priorqueryhistory",
      "type": "array"
    },
    "queryText": {
      "title": "Querytext",
      "type": "string"
    },
    "recentHiddenHypotheses": {
      "items": {
        "type": "string"
      },
      "title": "Recenthiddenhypotheses",
      "type": "array"
    },
    "recentObservationsSummary": {
      "items": {
        "$ref": "#/$defs/ObservationSummary"
      },
      "title": "Recentobservationssummary",
      "type": "array"
    },
    "roomMetadataSummary": {
      "$ref": "#/$defs/RoomMetadataSummary"
    },
    "sceneGraphSummary": {
      "$ref": "#/$defs/SceneGraphSummary"
    },
    "sessionMode": {
      "default": "live",
      "enum": [
        "live",
        "saved"
      ],
      "title": "Sessionmode",
      "type": "string"
    },
    "signalCapabilities": {
      "$ref": "#/$defs/SignalCapabilities"
    },
    "userAliases": {
      "additionalProperties": {
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "title": "Useraliases",
      "type": "object"
    },
    "voiceTranscriptConfidence": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Voicetranscriptconfidence"
    }
  },
  "required": [
    "queryText"
  ],
  "title": "QueryRequest",
  "type": "object"
}
